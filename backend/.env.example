NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_SSL=false
PG_BOSS_SCHEMA=pgboss

