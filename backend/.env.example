# Backend server
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/contentcategorize
DATABASE_SSL=false
# Optional: use a Supabase session pooler URL (port 5432) for pg-boss.
# Transaction poolers (port 6543) break LISTEN/NOTIFY and session locks.
PG_BOSS_DATABASE_URL=postgresql://postgres.zfhislpdajbjeltmmylg:[YOUR-PASSWORD]@aws-1-us-west-1.pooler.supabase.com:5432/postgres
PG_BOSS_SCHEMA=pgboss

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional platform metadata keys
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
YOUTUBE_API_KEY=
TWITTER_BEARER_TOKEN=

# AI metadata analyzer
GEMINI_API_KEY=

# CORS
CORS_ORIGIN=*
